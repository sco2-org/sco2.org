---
import Layout from "../layouts/Layout.astro";
import { es } from "../i18n/es";
import { BASE } from "../consts";

const t = es;
const lang = "es" as const;
---

<Layout
  title="Comunidades"
  description="Conoce los capítulos académicos, grupos de investigación y comunidades que impulsan el desarrollo de las ciencias de la computación en Colombia."
  lang={lang}
  t={t}
  canonicalURL="https://www.sco2.org/comunidades/"
>
  <section class="relative min-h-[60vh] flex items-center">
    <div class="absolute inset-0">
      <img
        src={`${BASE}images/comunidades.jpg`}
        alt="Comunidades SCo2"
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900/85 to-slate-900/40"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <div class="max-w-2xl">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight mb-6 animate-fade-in-up">
          {t.communities.heroTitle}
        </h1>
        <p class="text-lg sm:text-xl text-slate-200 mb-8 animate-fade-in-up animate-delay-100">
          {t.communities.heroSubtitle}
        </p>
        <a
          href={`${BASE}capitulos/`}
          class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-4 rounded-lg transition-colors text-lg animate-fade-in-up animate-delay-200"
        >
          {t.communities.heroCta}
        </a>
      </div>
    </div>
  </section>
</Layout>
