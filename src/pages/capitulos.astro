---
import Layout from "../layouts/Layout.astro";
import { es } from "../i18n/es";
import { chapters } from "../data/chapters";
import { BASE } from "../consts";

const t = es;
const lang = "es" as const;
---

<Layout
  title="Capítulos"
  description="Capítulos académicos de la Sociedad Colombiana de Computación"
  lang={lang}
  t={t}
  canonicalURL="https://www.sco2.org/capitulos/"
>
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl font-extrabold text-slate-900 mb-4">{t.chapters.title}</h1>
        <p class="text-xl text-slate-600">{t.chapters.subtitle}</p>
      </div>

      <div class="prose prose-slate max-w-none mb-16">
        <p class="text-lg text-slate-700">{t.chapters.intro}</p>
      </div>

      <h2 class="text-3xl font-bold text-slate-900 mb-10 text-center">{t.chapters.listTitle}</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-20">
        {chapters.map((ch) => (
          <div class="bg-slate-50 rounded-xl p-6 border border-slate-200 hover:border-blue-300 hover:shadow-md transition-all">
            <h3 class="font-bold text-slate-900 mb-3">{ch.nameEs}</h3>
            {ch.contactName && (
              <div class="text-sm text-slate-600 space-y-1">
                <p class="font-medium text-blue-700 text-xs uppercase tracking-wide mb-2">{t.chapters.contact}</p>
                <p class="font-medium">{ch.contactName}</p>
                <p>{ch.contactInstitution}</p>
                {ch.contactEmail && (
                  <a href={`mailto:${ch.contactEmail}`} class="inline-flex items-center gap-1 text-blue-600 hover:text-blue-800 text-xs font-medium mt-1">
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                    Enviar mensaje
                  </a>
                )}
              </div>
            )}
          </div>
        ))}
      </div>

      <div class="bg-blue-50 rounded-2xl p-8 sm:p-12 mb-20 border border-blue-100">
        <h2 class="text-2xl font-bold text-blue-900 mb-6">{t.chapters.createTitle}</h2>
        <p class="text-blue-800 mb-6">{t.chapters.createDesc}</p>
        <ol class="space-y-3 mb-8">
          {t.chapters.createSteps.map((step, i) => (
            <li class="flex gap-3 text-blue-800">
              <span class="font-bold text-blue-600 flex-shrink-0">{i + 1}.</span>
              <span>{step}</span>
            </li>
          ))}
        </ol>
        <a
          href={`${BASE}${t.chapters.createDoc.replace(/^\//, "")}`}
          class="inline-flex items-center gap-2 bg-blue-700 hover:bg-blue-800 text-white font-semibold px-6 py-3 rounded-lg transition-colors"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
          {t.chapters.createCta}
        </a>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-20">
        <div class="bg-white rounded-xl p-8 border border-slate-200">
          <h3 class="text-xl font-bold text-slate-900 mb-4">{t.chapters.benefitsTitle}</h3>
          <ul class="space-y-2">
            {t.chapters.benefits.map((b) => (
              <li class="flex items-start gap-2 text-slate-700">
                <svg class="h-5 w-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                {b}
              </li>
            ))}
          </ul>
          <p class="text-sm text-slate-500 mt-4 italic">{t.chapters.requirement}</p>
        </div>

        <div class="bg-slate-50 rounded-xl p-8 border border-slate-200">
          <h3 class="text-xl font-bold text-slate-900 mb-4">{t.chapters.infoTitle}</h3>
          <div class="space-y-3 text-slate-700">
            <p><span class="font-medium">Email:</span> <a href={`mailto:${t.chapters.infoEmail}`} class="text-blue-600 hover:text-blue-800">{t.chapters.infoEmail}</a></p>
            <p><span class="font-medium">Asunto:</span> {t.chapters.infoSubject}</p>
            <p class="text-sm text-slate-500 mt-4">Incluye en tu mensaje: nombre completo, teléfono, correo electrónico, institución o grupo de investigación.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
