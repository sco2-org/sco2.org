---
import Layout from "../../../layouts/Layout.astro";
import { en } from "../../../i18n/en";
import { eventDetails } from "../../../data/event-details";
import { BASE } from "../../../consts";

export function getStaticPaths() {
  return eventDetails.map((ev) => ({ params: { slug: ev.slug } }));
}

const { slug } = Astro.params;
const ev = eventDetails.find((e) => e.slug === slug);

if (!ev) {
  return Astro.redirect("/en/404");
}

const t = en;
const lang = "en" as const;
const catLabel = ev.category === "ccc" ? "CCC" : ev.category === "sipeco" ? "SIPECO" : "SMD";
const catColor = ev.category === "ccc" ? "blue" : ev.category === "sipeco" ? "green" : "purple";
---

<Layout
  title={ev.titleEn}
  description={ev.descriptionEn}
  lang={lang}
  t={t}
  canonicalURL={`https://www.sco2.org/en/evento/${ev.slug}/`}
>
  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href={`${BASE}en/events/`} class="inline-flex items-center gap-1 text-sm text-slate-500 hover:text-blue-700 mb-8 transition-colors">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
        Events
      </a>

      <div class="mb-8">
        <span class={`inline-block text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full bg-${catColor}-100 text-${catColor}-700 mb-4`}>{catLabel} · {ev.year}</span>
        <h1 class="text-4xl font-extrabold text-slate-900 leading-tight">{ev.titleEn}</h1>
        {ev.subtitleEn && <p class="text-xl text-blue-700 font-semibold mt-2">{ev.subtitleEn}</p>}
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-12 p-6 bg-slate-50 rounded-xl">
        {ev.datesEn && (
          <div>
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Dates</p>
            <p class="text-slate-800 font-medium">{ev.datesEn}</p>
          </div>
        )}
        {ev.cityEn && (
          <div>
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">City</p>
            <p class="text-slate-800 font-medium">{ev.cityEn}</p>
          </div>
        )}
        {ev.venueEn && (
          <div>
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Venue</p>
            <p class="text-slate-800 font-medium">{ev.venueEn}</p>
          </div>
        )}
      </div>

      <div class="prose prose-slate max-w-none mb-12">
        <p class="text-lg text-slate-700 leading-relaxed">{ev.descriptionEn}</p>
      </div>

      {ev.organizerEn && (
        <div class="mb-12">
          <h2 class="text-xl font-bold text-slate-900 mb-3">Organizer</h2>
          <p class="text-slate-700">{ev.organizerEn}</p>
        </div>
      )}

      {ev.themesEn && ev.themesEn.length > 0 && (
        <div class="mb-12">
          <h2 class="text-xl font-bold text-slate-900 mb-4">Topics</h2>
          <div class="flex flex-wrap gap-2">
            {ev.themesEn.map((theme) => (
              <span class="px-3 py-1.5 bg-slate-100 text-slate-700 rounded-full text-sm">{theme}</span>
            ))}
          </div>
        </div>
      )}

      {ev.importantDatesEn && ev.importantDatesEn.length > 0 && (
        <div class="mb-12 bg-amber-50 rounded-xl p-6 border border-amber-100">
          <h2 class="text-xl font-bold text-amber-900 mb-4">Important Dates</h2>
          <ul class="space-y-2">
            {ev.importantDatesEn.map((d) => (
              <li class="flex items-start gap-2 text-amber-800 text-sm">
                <svg class="h-5 w-5 text-amber-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                {d}
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>
  </section>
</Layout>
