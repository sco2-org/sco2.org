---
import Layout from "../../layouts/Layout.astro";
import { en } from "../../i18n/en";
import { eventDetails } from "../../data/event-details";
import { BASE } from "../../consts";

const t = en;
const lang = "en" as const;

const cccEvents = eventDetails.filter((e) => e.category === "ccc");
const sipecoEvents = eventDetails.filter((e) => e.category === "sipeco");
const smdEvents = eventDetails.filter((e) => e.category === "smd");
---

<Layout
  title="Events"
  description="Event history of the Colombian Computer Society — CCC, SIPECO, SMD"
  lang={lang}
  t={t}
  canonicalURL="https://www.sco2.org/en/events/"
>
  <section class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h1 class="text-4xl font-extrabold text-slate-900 mb-4">Events</h1>
        <p class="text-xl text-slate-600">Event history of the Colombian Computer Society</p>
      </div>

      <section class="mb-20">
        <h2 class="text-2xl font-bold text-slate-900 mb-2">CCC — Colombian Computing Conferences</h2>
        <p class="text-slate-500 mb-8">Annual meeting that brings together researchers, students and computing professionals in Colombia.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {cccEvents.map((ev) => (
            <a href={`${BASE}en/evento/${ev.slug}/`} class="flex items-center gap-3 bg-slate-50 hover:bg-blue-50 rounded-lg p-4 border border-slate-200 hover:border-blue-200 transition-all group">
              <span class="flex-shrink-0 w-10 h-10 bg-blue-100 text-blue-700 rounded-full flex items-center justify-center text-sm font-bold">{ev.year}</span>
              <div class="min-w-0 flex-1">
                <span class="text-sm font-medium text-slate-700 group-hover:text-blue-700 block truncate">{ev.titleEn}</span>
                {ev.cityEn && <span class="text-xs text-slate-400">{ev.cityEn}</span>}
              </div>
              <svg class="h-4 w-4 text-slate-300 group-hover:text-blue-500 flex-shrink-0 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </a>
          ))}
        </div>
      </section>

      <section class="mb-20">
        <h2 class="text-2xl font-bold text-slate-900 mb-2">SIPECO — Research Seminar on Computational Thinking</h2>
        <p class="text-slate-500 mb-8">Space to share advances in the development of computational thinking.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {sipecoEvents.map((ev) => (
            ev.externalUrl ? (
              <a href={ev.externalUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 bg-slate-50 hover:bg-green-50 rounded-lg p-4 border border-slate-200 hover:border-green-200 transition-all group">
                <span class="flex-shrink-0 w-10 h-10 bg-green-100 text-green-700 rounded-full flex items-center justify-center text-sm font-bold">{ev.year}</span>
                <div class="min-w-0 flex-1">
                  <span class="text-sm font-medium text-slate-700 group-hover:text-green-700 block truncate">{ev.titleEn}</span>
                </div>
                <svg class="h-4 w-4 text-slate-300 group-hover:text-green-500 flex-shrink-0 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
              </a>
            ) : (
              <a href={`${BASE}en/evento/${ev.slug}/`} class="flex items-center gap-3 bg-slate-50 hover:bg-green-50 rounded-lg p-4 border border-slate-200 hover:border-green-200 transition-all group">
                <span class="flex-shrink-0 w-10 h-10 bg-green-100 text-green-700 rounded-full flex items-center justify-center text-sm font-bold">{ev.year}</span>
                <div class="min-w-0 flex-1">
                  <span class="text-sm font-medium text-slate-700 group-hover:text-green-700 block truncate">{ev.titleEn}</span>
                </div>
                <svg class="h-4 w-4 text-slate-300 group-hover:text-green-500 flex-shrink-0 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
              </a>
            )
          ))}
        </div>
      </section>

      <section class="mb-20">
        <h2 class="text-2xl font-bold text-slate-900 mb-2">SMD — Master's and Doctoral Symposia</h2>
        <p class="text-slate-500 mb-8">Forum for graduate students to present their research.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {smdEvents.map((ev) => (
            <a href={`${BASE}en/evento/${ev.slug}/`} class="flex items-center gap-3 bg-slate-50 hover:bg-purple-50 rounded-lg p-4 border border-slate-200 hover:border-purple-200 transition-all group">
              <span class="flex-shrink-0 w-10 h-10 bg-purple-100 text-purple-700 rounded-full flex items-center justify-center text-sm font-bold">{ev.year}</span>
              <div class="min-w-0 flex-1">
                <span class="text-sm font-medium text-slate-700 group-hover:text-purple-700 block truncate">{ev.titleEn}</span>
              </div>
              <svg class="h-4 w-4 text-slate-300 group-hover:text-purple-500 flex-shrink-0 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
            </a>
          ))}
        </div>
      </section>
    </div>
  </section>
</Layout>
