---
import Layout from "../layouts/Layout.astro";
import ContactForm from "../components/ContactForm.astro";
import { es } from "../i18n/es";
import { BASE } from "../consts";

const t = es;
const lang = "es" as const;
---

<Layout
  title="Inicio"
  description="Conectamos academia, industria, investigación y talento para fortalecer la comunidad computacional del país, promover la innovación y generar impacto real en la sociedad."
  lang={lang}
  t={t}
>
  <section class="relative min-h-[85vh] flex items-center">
    <div class="absolute inset-0">
      <img
        src={`${BASE}images/hero.jpg`}
        alt="Computación en Colombia"
        class="w-full h-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900/85 to-slate-900/40"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32">
      <div class="max-w-2xl">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6 animate-fade-in-up">
          {t.home.heroTitle}
        </h1>
        <p class="text-lg sm:text-xl text-slate-200 mb-8 animate-fade-in-up animate-delay-100">
          {t.home.heroSubtitle}
        </p>
        <a
          href={`${BASE}#about`}
          class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold px-8 py-4 rounded-lg transition-colors text-lg animate-fade-in-up animate-delay-200"
        >
          {t.home.heroCta}
        </a>
      </div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 h-24 bg-gradient-to-t from-white to-transparent"></div>
  </section>

  <section id="about" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-4">{t.home.eventsTitle}</h2>
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">{t.home.eventsSubtitle}</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <a href={`${BASE}20ccc/`} class="group block bg-white rounded-2xl shadow-lg hover:shadow-xl transition-all overflow-hidden border border-slate-100">
          <div class="h-48 overflow-hidden">
            <img src={`${BASE}images/20ccc-card.jpg`} alt="20CCC" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-blue-700 transition-colors">{t.home.ccc20Title}</h3>
            <div class="flex items-center gap-4 text-sm text-slate-500 mb-3">
              <span class="flex items-center gap-1">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                {t.home.ccc20Date}
              </span>
              <span class="flex items-center gap-1">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                {t.home.ccc20Location}
              </span>
            </div>
            <p class="text-slate-600 text-sm">{t.home.ccc20Desc}</p>
          </div>
        </a>

        <div class="block bg-white rounded-2xl shadow-lg border border-slate-100 overflow-hidden">
          <div class="h-48 overflow-hidden">
            <img src={`${BASE}images/assembly.jpg`} alt="Asamblea SCo2" class="w-full h-full object-cover" />
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-slate-900 mb-3">{t.home.assemblyTitle}</h3>
            <div class="flex items-center gap-4 text-sm text-slate-500 mb-3">
              <span class="flex items-center gap-1">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
                {t.home.assemblyDate}
              </span>
              <span class="flex items-center gap-1">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                {t.home.ccc20Location}
              </span>
            </div>
            <p class="text-slate-600 text-sm">{t.home.assemblyDesc}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="join" class="py-20 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-6">{t.home.joinTitle}</h2>
          <p class="text-lg text-slate-600 mb-8">{t.home.joinDesc}</p>
          <a
            href={`${BASE}miembros/`}
            class="inline-block bg-blue-700 hover:bg-blue-800 text-white font-semibold px-8 py-4 rounded-lg transition-colors text-lg"
          >
            {t.home.joinCta}
          </a>
        </div>
        <div class="relative">
          <img
            src={`${BASE}images/join-community.jpg`}
            alt="Comunidad SCo2"
            class="w-full rounded-2xl shadow-lg"
            loading="lazy"
          />
          <div class="absolute inset-0 rounded-2xl bg-blue-700/10"></div>
        </div>
      </div>
    </div>
  </section>

  <ContactForm t={t.home} lang={lang} />
</Layout>
