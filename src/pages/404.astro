---
import Layout from "../layouts/Layout.astro";
import { es } from "../i18n/es";

const t = es;
---

<Layout
  title="Página no encontrada"
  description="La página que buscas no existe."
  lang="es"
  t={t}
>
  <div class="min-h-[60vh] flex items-center justify-center py-20">
    <div class="text-center px-4">
      <h1 class="text-8xl font-extrabold text-blue-600 mb-4">404</h1>
      <h2 class="text-2xl font-bold text-slate-900 mb-4">Página no encontrada</h2>
      <p class="text-slate-600 mb-8 max-w-md mx-auto">
        La página que buscas no existe o ha sido movida.
      </p>
      <a
        href="/"
        class="inline-block bg-blue-700 hover:bg-blue-800 text-white font-semibold px-8 py-3 rounded-lg transition-colors"
      >
        Volver al inicio
      </a>
    </div>
  </div>
</Layout>
