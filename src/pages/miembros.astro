---
import Layout from "../layouts/Layout.astro";
import { es } from "../i18n/es";
import { BASE } from "../consts";

const t = es;
const lang = "es" as const;
---

<Layout
  title="Membresías"
  description="Conviértete en miembro de la Sociedad Colombiana de Computación"
  lang={lang}
  t={t}
  canonicalURL="https://www.sco2.org/miembros/"
>
  <section class="relative min-h-[60vh] flex items-center">
    <div class="absolute inset-0">
      <img
        src={`${BASE}images/miembros.jpg`}
        alt="Membresías SCo2"
        class="w-full h-full object-cover"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-slate-900/85 to-slate-900/40"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <div class="max-w-2xl">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white leading-tight mb-6 animate-fade-in-up">
          {t.home.membersTitle}
        </h1>
        <p class="text-lg sm:text-xl text-slate-200 animate-fade-in-up animate-delay-100">
          {t.home.membersDesc}
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
        <div class="bg-slate-50 rounded-xl p-8 text-center border border-slate-200">
          <div class="w-14 h-14 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="h-7 w-7 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">{t.home.membersProfessional}</h3>
          <p class="text-sm text-slate-600">{t.home.membersProfessionalDesc}</p>
        </div>
        <div class="bg-slate-50 rounded-xl p-8 text-center border border-slate-200">
          <div class="w-14 h-14 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="h-7 w-7 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M12 14l9-5-9-5-9 5 9 5z" /><path d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z" /></svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">{t.home.membersStudent}</h3>
          <p class="text-sm text-slate-600">{t.home.membersStudentDesc}</p>
        </div>
        <div class="bg-slate-50 rounded-xl p-8 text-center border border-slate-200">
          <div class="w-14 h-14 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="h-7 w-7 text-purple-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>
          </div>
          <h3 class="text-lg font-bold text-slate-900 mb-2">{t.home.membersInstitutional}</h3>
          <p class="text-sm text-slate-600">{t.home.membersInstitutionalDesc}</p>
        </div>
      </div>

      <div class="bg-amber-50 border border-amber-200 rounded-2xl p-8 text-center">
        <svg class="h-10 w-10 text-amber-500 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <p class="text-amber-800 font-medium text-lg mb-2">{t.home.membersComingSoon}</p>
        <p class="text-amber-700 text-sm">{t.home.membersContact} <a href="mailto:contacto@sco2.org" class="text-blue-600 hover:text-blue-800 font-medium">contacto@sco2.org</a></p>
      </div>
    </div>
  </section>
</Layout>
